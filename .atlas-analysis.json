  "keyFeatures": [
    "Multi-provider menu bar with per-provider toggles",
    "Session and weekly usage meters with reset countdowns",
    "Bundled CLI for scripts and CI",
    "Merge Icons mode to combine providers into one status item",
    "Privacy-first on-device parsing with opt-in browser cookies",
    "WidgetKit widget mirrors for menu card snapshots",
    "OpenAI web dashboard enrichments for code review and usage breakdown",
    "Local cost-usage scanning for last 30 days"
  ],
  "publicApiSurface": [
